  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun"],
    "skipLibCheck": true,
    "strict": true,
    "checkJs": false
  },
  "include": ["server.ts", "bin/**/*.ts"],
  "exclude": ["node_modules/**", "build/**"]
}
