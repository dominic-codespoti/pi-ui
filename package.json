{
  "name": "@thed24/pi-ui",
  "version": "0.2.4",
  "description": "Web UI for the pi coding agent — runs in your browser, served from a Raspberry Pi or any Bun-capable machine.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/dominic-codespoti/pi-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dominic-codespoti/pi-ui.git"
  },
  "bugs": {
    "url": "https://github.com/dominic-codespoti/pi-ui/issues"
  },
  "keywords": ["pi", "coding-agent", "ai", "pwa", "bun", "svelte"],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "pi-ui": "./bin/pifrontier"
  },
  "files": [
    "bin/",
    "build/",
    "!build/**/*.map",
    "scripts/",
    "src/lib/auth/password.ts",
    "src/lib/auth/rate-limiter.ts",
    "src/lib/markdown.ts",
    "src/lib/ws/protocol.ts",
    "server.ts",
    "server.bundle.js"
  ],
  "scripts": {
    "dev": "vite dev",
    "dev:ws": "PORT=5174 DEV_WS_ONLY=true bun --watch server.ts",
    "dev:full": "bun scripts/dev.ts",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:server": "tsc --noEmit --project tsconfig.server.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "bun --smol run bin/pifrontier.ts",
    "build:server": "bun build ./server.ts --target bun --outfile ./server.bundle.js --minify --external './build/handler.js' --external '@earendil-works/pi-coding-agent' --external '@earendil-works/pi-ai' --external 'bcryptjs' --external 'jose'",
    "test": "bun test src/lib/auth --timeout 15000",
    "prepublishOnly": "bun run build && bun run build:server"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "bcryptjs": "^2.4.3",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.17.0",
    "@sveltejs/kit": "^2.62.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.14",
    "daisyui": "^5.5.20",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.56.1",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.5.0",
    "tailwindcss": "^4.3.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  }
}
