{
  "name": "pi-ui",
  "version": "0.1.0",
  "description": "Web UI for the pi coding agent — runs in your browser, served from a Raspberry Pi or any Bun-capable machine.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/dominic-codespoti/pi-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dominic-codespoti/pi-ui.git"
  },
  "bugs": {
    "url": "https://github.com/dominic-codespoti/pi-ui/issues"
  },
  "keywords": ["pi", "coding-agent", "ai", "pwa", "bun", "svelte"],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "pi-ui": "./bin/pi-ui.ts"
  },
  "files": [
    "bin/",
    "build/",
    "src/lib/",
    "server.ts"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:server": "tsc --noEmit --project tsconfig.server.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "bun --smol run bin/pi-ui.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.14",
    "autoprefixer": "^10.5.0",
    "daisyui": "4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.0.0",
    "svelte-adapter-bun": "^0.5.2",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7"
  }
}
