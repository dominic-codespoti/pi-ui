{
  "name": "@thed24/pi-ui",
  "version": "0.8.1",
  "description": "Web UI for the pi coding agent — runs in your browser, served from a Raspberry Pi or any Bun-capable machine.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/dominic-codespoti/pi-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dominic-codespoti/pi-ui.git"
  },
  "bugs": {
    "url": "https://github.com/dominic-codespoti/pi-ui/issues"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "ai",
    "pwa",
    "bun",
    "svelte"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pi-ui": "./bin/pifrontier"
  },
  "files": [
    "bin/",
    "build/",
    "!build/**/*.map",
    "scripts/",
    "src/lib/auth/password.ts",
    "src/lib/auth/rate-limiter.ts",
    "src/lib/markdown.ts",
    "src/lib/tui-stubs.ts",
    "src/lib/ws/protocol.ts",
    "server.ts",
    "server.bundle.js"
  ],
  "scripts": {
    "dev": "vite dev",
    "dev:ws": "PORT=5174 DEV_WS_ONLY=true bun --watch server.ts",
    "dev:full": "bun scripts/dev.ts",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:server": "tsc --noEmit --project tsconfig.server.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "bun --smol run bin/pifrontier.ts",
    "build:server": "bun build ./server.ts --target bun --outfile ./server.bundle.js --minify --external './build/handler.js' --external '@earendil-works/pi-coding-agent' --external '@earendil-works/pi-ai'",
    "test": "bun test src/lib/auth --timeout 15000",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:ci": "bun run check && bun run check:server && bun run lint && bun run test:unit && bun run test:e2e",
    "prepublishOnly": "bun run build && bun run build:server"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@eslint/js": "^10.0.1",
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.10",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.6.18",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "marked": "^18.0.6",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.7.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
